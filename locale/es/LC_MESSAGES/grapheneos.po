msgid ""
"A 3rd party community-sourced effort containing\n"
"                "
msgstr ""

#: static/usage.html:1114
msgid ""
"banking\n"
"                app compatibility"
msgstr ""

#: static/usage.html:1115
msgid ""
" information is maintained by PrivSec.dev. GrapheneOS does\n"
"                not make any guarantees regarding the list's validity."
msgstr ""

